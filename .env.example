# Convex Configuration
# Run `npx convex dev` in packages/backend to get these values

CONVEX_DEPLOYMENT=

# Frontend URLs (used by both apps)
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=

# Mantle Blockchain Configuration
# Get a deployer private key from your wallet (for contract deployment + oracle signing)
DEPLOYER_PRIVATE_KEY=
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_EXPLORER_API_KEY=

# Venice AI (privacy-preserving hints)
# Sign up at https://venice.ai for an API key
VENICE_API_KEY=

# Archive paywall (Polygon Amoy)
# Closed-episode SUMMARY data is FREE — any caller can fetch it via
#   GET /api/archive/:episodeId?detail=summary
# (no identityId required, no payment header).
#
# Full rich content (scenes, hotspots, ambient text, leaderboard) is still
# gated behind a 1 USDC payment on Polygon Amoy. The treasury wallet that
# receives those unlock payments is configured via:
PAYWALL_TREASURY_ADDRESS=
POLYGON_AMOY_RPC_URL=https://rpc.amoy.polygon.io
