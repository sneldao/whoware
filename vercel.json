{
  "buildCommand": "cd apps/default && npx expo export --platform web",
  "outputDirectory": "apps/default/dist",
  "installCommand": "npm install --legacy-peer-deps",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://colorless-seal-981.convex.site/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
