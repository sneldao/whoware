{
  "name": "bloom-monorepo-template",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@bloom/backend",
    "dev:mobile": "turbo run dev --filter=@bloom/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "^2.0.12"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "^1.30.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix --no-warn-ignored"
    ]
  },
  "packageManager": "bun@1.3.6"
}
