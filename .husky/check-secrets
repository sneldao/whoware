#!/usr/bin/env sh

# Secrets scanner — checks staged files for common secret patterns.
# Runs before lint-staged in the pre-commit hook.

set -e

PATTERNS='(PRIVATE[_-]?KEY|SECRET[_-]?KEY|API[_-]?KEY|ACCESS[_-]?TOKEN|AUTH[_-]?TOKEN|DEPLOYER[_-]?PRIVATE)'
HEX_KEY='0x[0-9a-fA-F]{64}'
AWS_KEY='AKIA[0-9A-Z]{16}'

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '\.(png|jpg|jpeg|gif|ttf|woff|woff2|ico)$' || true)

if [ -z "$FILES" ]; then
  exit 0
fi

FOUND=0

for file in $FILES; do
  if file "$file" 2>/dev/null | grep -q "binary"; then continue; fi
  if echo "$file" | grep -qE '(_generated/|node_modules/|\.lock)'; then continue; fi

  MATCHES=$(grep -nEi "($PATTERNS|$HEX_KEY|$AWS_KEY)" "$file" 2>/dev/null | grep -vE '(process\.env|\.env\.example|import |require\(|from |//|\.d\.ts|README|callVenice|Bearer \$\{|throw new Error|if \(!apiKey|const apiKey = process\.env|if \(!privateKey|privateKeyToAccount|DEPLOYER_PRIVATE_KEY.*oracle signing|Missing DEPLOYER_PRIVATE_KEY|apiKey: string|apiKey,|AGENTS_API_KEY|ORACLE_ADDRESS)' || true)

  if [ -n "$MATCHES" ]; then
    echo ""
    echo "Potential secret found in $file:"
    echo "$MATCHES" | while read -r line; do
      echo "   $line"
    done
    FOUND=1
  fi
done

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo "Secrets check failed. Review the matches above."
  echo "If these are false positives, add them to the exclusion list in .husky/check-secrets."
  exit 1
fi

echo "No secrets detected in staged files."
