{
    "expo": {
        "name": "WhoWare",
        "slug": "whoware",
        "version": "1.0.0",
        "runtimeVersion": {
            "policy": "sdkVersion"
        },
        "orientation": "portrait",
        "icon": "../../assets/images/icon.png",
        "scheme": "whoware",
        "userInterfaceStyle": "dark",
        "newArchEnabled": true,
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "com.whoware.app",
            "backgroundColor": "#070A12"
        },
        "android": {
            "package": "com.whoware.app",
            "adaptiveIcon": {
                "foregroundImage": "../../assets/images/adaptive-icon.png",
                "backgroundColor": "#070A12"
            }
        },
        "web": {
            "bundler": "metro",
            "output": "single",
            "favicon": "../../assets/images/favicon.png"
        },
        "plugins": [
            "expo-router",
            [
                "expo-splash-screen",
                {
                    "image": "../../assets/images/splash-icon.png",
                    "imageWidth": 200,
                    "resizeMode": "contain",
                    "backgroundColor": "#070A12"
                }
            ],
            "expo-secure-store",
            "expo-font",
            "expo-web-browser"
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}